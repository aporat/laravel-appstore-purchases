{
  "name": "aporat/laravel-appstore-purchases",
  "description": "Laravel package for handling App Store purchase receipts, subscriptions and notifications",
  "type": "library",
  "license": "MIT",
  "homepage": "https://github.com/aporat/laravel-appstore-purchases",
  "keywords": [
    "laravel",
    "app store",
    "apple",
    "amazon",
    "itunes",
    "in-app purchase",
    "subscription",
    "receipt validation",
    "server notifications"
  ],
  "authors": [
    {
      "name": "Adar Porat",
      "email": "aporat28@gmail.com",
      "homepage": "https://github.com/aporat",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.4",
    "ext-json": "*",
    "ext-openssl": "*",
    "illuminate/support": "^12.0 || ^13.0",
    "aporat/store-receipt-validator": "dev-main"
  },
  "require-dev": {
    "orchestra/testbench": "^10.0 || ^11.0",
    "laravel/pint": "^1.21",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^12.0 || ^13.0",
    "mockery/mockery": "^1.6"
  },
  "autoload": {
    "psr-4": {
      "Aporat\\AppStorePurchases\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Aporat\\AppStorePurchases\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Aporat\\AppStorePurchases\\AppStorePurchasesServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "test-ci": "vendor/bin/phpunit --coverage-text --coverage-clover coverage.xml --log-junit junit.xml",
    "check": "vendor/bin/pint --test",
    "analyze": "vendor/bin/phpstan analyse src --level=5 --memory-limit=-1"
  },
  "support": {
    "issues": "https://github.com/aporat/laravel-appstore-purchases/issues",
    "source": "https://github.com/aporat/laravel-appstore-purchases"
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}